{
  "name": "temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:auth": "playwright test --config=e2e/playwright.config.ts e2e/auth-flows.spec.ts",
    "test:e2e:payments": "playwright test --config=e2e/playwright.config.ts e2e/payments.spec.ts",
    "test:e2e:a11y": "playwright test --config=e2e/playwright.config.ts e2e/accessibility.spec.ts",
    "test:e2e:smoke": "playwright test --config=e2e/playwright.config.ts e2e/smoke.spec.ts",
    "test:e2e:critical": "playwright test --config=e2e/playwright.config.ts e2e/critical-path.spec.ts",
    "test:load": "bash load-tests/run.sh local",
    "test:load:prod": "bash load-tests/run.sh prod",
    "test:smoke": "k6 run --env BASE_URL=http://localhost:3000 load-tests/scenarios/smoke-test.js",
    "db:link": "supabase link --project-ref tyustwqwvjmzvuazfwkv",
    "db:migration:create": "supabase migration new",
    "db:migration:up": "supabase migration up",
    "db:migration:list": "supabase migration list",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --schema guildos_core",
    "db:types": "supabase gen types typescript --linked > src/lib/types/database.ts",
    "db:seed": "bash ../scripts/migrate.sh --seed-only"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/ssr": "^0.12.0",
